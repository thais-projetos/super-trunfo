#include <stdio.h>
#include <string.h>

// Estrutura para representar uma cidade
typedef struct {
    char estado[50];
    int codigo;
    char nome[50];
    long populacao;
    double pib; // Em bilhões
    double area; // Em km²
    int pontos_turisticos;
    double densidade_populacional; // Habitantes por km²
    double pib_per_capita; // PIB per capita em reais
} Cidade;

// Função para calcular densidade populacional e PIB per capita
void calcularPropriedades(Cidade *cidade) {
    cidade->densidade_populacional = cidade->populacao / cidade->area;
    cidade->pib_per_capita = (cidade->pib * 1e9) / cidade->populacao; // PIB em reais dividido pela população
}

// Função para exibir os dados de uma cidade
void exibirCidade(Cidade cidade) {
    printf("\n--- Dados da Cidade ---\n");
    printf("Estado: %s\n", cidade.estado);
    printf("Codigo: %d\n", cidade.codigo);
    printf("Nome: %s\n", cidade.nome);
    printf("Populacao: %ld habitantes\n", cidade.populacao);
    printf("PIB: %.2f bilhoes\n", cidade.pib);
    printf("Area: %.2f km²\n", cidade.area);
    printf("Pontos Turisticos: %d\n", cidade.pontos_turisticos);
    printf("Densidade Populacional: %.2f hab/km²\n", cidade.densidade_populacional);
    printf("PIB per capita: %.2f reais\n", cidade.pib_per_capita);
}

// Função para o jogador escolher um atributo
int escolherAtributo() {
    int escolha;
    printf("\nEscolha um atributo para comparar:\n");
    printf("1 - Populacao\n");
    printf("2 - PIB\n");
    printf("3 - Area\n");
    printf("4 - Pontos Turisticos\n");
    printf("5 - Densidade Populacional\n");
    printf("6 - PIB per capita\n");
    scanf("%d", &escolha);
    return escolha;
}

int main() {
    Cidade jogador, computador;

    // Entrada de dados para a carta do jogador
    printf("Registro da Carta do Jogador:\n");
    printf("Estado: ");
    scanf("%s", jogador.estado);
    printf("Codigo: ");
    scanf("%d", &jogador.codigo);
    printf("Nome da Cidade: ");
    scanf("%s", jogador.nome);
    printf("Populacao: ");
    scanf("%ld", &jogador.populacao);
    printf("PIB (em bilhoes): ");
    scanf("%lf", &jogador.pib);
    printf("Area (em km²): ");
    scanf("%lf", &jogador.area);
    printf("Pontos Turisticos: ");
    scanf("%d", &jogador.pontos_turisticos);

    // Calcula propriedades derivadas
    calcularPropriedades(&jogador);

    // Entrada de dados para a carta do computador
    printf("\nRegistro da Carta do Computador:\n");
    printf("Estado: ");
    scanf("%s", computador.estado);
    printf("Codigo: ");
    scanf("%d", &computador.codigo);
    printf("Nome da Cidade: ");
    scanf("%s", computador.nome);
    printf("Populacao: ");
    scanf("%ld", &computador.populacao);
    printf("PIB (em bilhoes): ");
    scanf("%lf", &computador.pib);
    printf("Area (em km²): ");
    scanf("%lf", &computador.area);
    printf("Pontos Turisticos: ");
    scanf("%d", &computador.pontos_turisticos);

    // Calcula propriedades derivadas
    calcularPropriedades(&computador);

    // Exibe as cartas
    printf("\nCarta do Jogador:\n");
    exibirCidade(jogador);

    printf("\nCarta do Computador:\n");
    exibirCidade(computador);

    // Jogador escolhe um atributo para comparar
    int escolha = escolherAtributo();

    // Comparação dos atributos
    double valorJogador, valorComputador;
    char atributoEscolhido[50];

    switch (escolha) {
        case 1:
            valorJogador = jogador.populacao;
            valorComputador = computador.populacao;
            strcpy(atributoEscolhido, "Populacao");
            break;
        case 2:
            valorJogador = jogador.pib;
            valorComputador = computador.pib;
            strcpy(atributoEscolhido, "PIB");
            break;
        case 3:
            valorJogador = jogador.area;
            valorComputador = computador.area;
            strcpy(atributoEscolhido, "Area");
            break;
        case 4:
            valorJogador = jogador.pontos_turisticos;
            valorComputador = computador.pontos_turisticos;
            strcpy(atributoEscolhido, "Pontos Turisticos");
            break;
        case 5:
            valorJogador = jogador.densidade_populacional;
            valorComputador = computador.densidade_populacional;
            strcpy(atributoEscolhido, "Densidade Populacional");
            break;
        case 6:
            valorJogador = jogador.pib_per_capita;
            valorComputador = computador.pib_per_capita;
            strcpy(atributoEscolhido, "PIB per capita");
            break;
        default:
            printf("Escolha invalida!\n");
            return 1;
    }

    // Exibe o resultado da comparação
    printf("\nComparando %s...\n", atributoEscolhido);
    if (valorJogador > valorComputador) {
        printf("Voce venceu!\n");
    } else if (valorJogador < valorComputador) {
        printf("O computador venceu!\n");
    } else {
        printf("Empate!\n");
    }

    return 0;
}